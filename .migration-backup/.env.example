# Base URL of the Django REST Framework API, including the /api/v1 prefix.
# Defaults to the deployed backend if unset — see lib/api-client.ts.
NEXT_PUBLIC_API_BASE_URL=https://salvageme.pythonanywhere.com/api/v1
# "live" (default) talks to NEXT_PUBLIC_API_BASE_URL. "mock" uses the
# in-memory mock adapter (lib/mock-adapter.ts) for local dev without a
# running backend.
NEXT_PUBLIC_API_MODE=live
