# Base URL of the Django REST Framework API. Leave unset to use the built-in
# in-memory mock adapter (see lib/api-client.ts / lib/mock-adapter.ts).
NEXT_PUBLIC_API_BASE_URL=
# "mock" | "live" — forces the adapter explicitly; falls back to mock if
# NEXT_PUBLIC_API_BASE_URL is empty.
NEXT_PUBLIC_API_MODE=mock
